<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent" >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".MainActivity" >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/player_one_counter_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"

            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toTopOf="@+id/player_two_counter_field"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="spread">

            <TextView
                android:id="@+id/player_one_name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="24dp"
                android:text="@string/player_one"
                android:textAppearance="@style/TextAppearance.AppCompat.Display1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/player_one_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="24dp"
                android:text="00"
                android:textAppearance="@style/TextAppearance.AppCompat.Display1"
                app:layout_constraintStart_toEndOf="@+id/player_one_name_label"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_one_btn_counter_one"
                android:onClick="onPointsButtonClicked"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"

                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"

                app:icon="@drawable/outline_counter_1_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/player_one_name_label"
                app:tint="?attr/colorOnBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_one_btn_counter_three"
                android:onClick="onPointsButtonClicked"

                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                app:icon="@drawable/outline_counter_3_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toEndOf="@+id/player_one_btn_counter_one"
                app:layout_constraintTop_toBottomOf="@+id/player_one_name_label"
                app:tint="?attr/colorOnBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_one_btn_counter_six"
                android:onClick="onPointsButtonClicked"

                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                app:icon="@drawable/outline_counter_6_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toEndOf="@+id/player_one_btn_counter_three"
                app:layout_constraintTop_toBottomOf="@+id/player_one_name_label"
                app:tint="?attr/colorOnBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_one_btn_counter_nine"
                android:onClick="onPointsButtonClicked"

                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                app:icon="@drawable/outline_counter_9_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toEndOf="@+id/player_one_btn_counter_six"
                app:layout_constraintTop_toBottomOf="@+id/player_one_name_label"
                app:tint="?attr/colorOnBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_one_btn_counter_twelve"
                android:onClick="onPointsButtonClicked"

                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                app:icon="@drawable/outline_award_star_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toEndOf="@+id/player_one_btn_counter_nine"
                app:layout_constraintTop_toBottomOf="@+id/player_one_name_label"
                app:tint="?attr/colorOnBackground" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/player_two_counter_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"

            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toTopOf="@+id/actions_button_field"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/player_one_counter_field">

            <TextView
                android:id="@+id/player_two_name_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="24dp"
                android:text="@string/player_two"
                android:textAppearance="@style/TextAppearance.AppCompat.Display1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/player_two_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="24dp"
                android:text="00"
                android:textAppearance="@style/TextAppearance.AppCompat.Display1"
                app:layout_constraintStart_toEndOf="@+id/player_two_name_label"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_two_btn_counter_one"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"

                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:onClick="onPointsButtonClicked"
                android:padding="0dp"

                app:icon="@drawable/outline_counter_1_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/player_two_name_label"
                app:tint="?attr/colorOnBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_two_btn_counter_three"
                style="@style/Widget.Material3.Button.IconButton"

                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:onClick="onPointsButtonClicked"
                android:padding="0dp"
                app:icon="@drawable/outline_counter_3_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toEndOf="@+id/player_two_btn_counter_one"
                app:layout_constraintTop_toBottomOf="@+id/player_two_name_label"
                app:tint="?attr/colorOnBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_two_btn_counter_six"
                style="@style/Widget.Material3.Button.IconButton"

                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:onClick="onPointsButtonClicked"
                android:padding="0dp"
                app:icon="@drawable/outline_counter_6_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toEndOf="@+id/player_two_btn_counter_three"
                app:layout_constraintTop_toBottomOf="@+id/player_two_name_label"
                app:tint="?attr/colorOnBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_two_btn_counter_nine"
                style="@style/Widget.Material3.Button.IconButton"

                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:onClick="onPointsButtonClicked"
                android:padding="0dp"
                app:icon="@drawable/outline_counter_9_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toEndOf="@+id/player_two_btn_counter_six"
                app:layout_constraintTop_toBottomOf="@+id/player_two_name_label"
                app:tint="?attr/colorOnBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/player_two_btn_counter_twelve"
                style="@style/Widget.Material3.Button.IconButton"

                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="16dp"
                android:contentDescription="Ação de alto destaque"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:onClick="onPointsButtonClicked"
                android:padding="0dp"
                app:icon="@drawable/outline_award_star_24"
                app:iconPadding="0dp"
                app:iconSize="52dp"
                app:layout_constraintStart_toEndOf="@+id/player_two_btn_counter_nine"
                app:layout_constraintTop_toBottomOf="@+id/player_two_name_label"
                app:tint="?attr/colorOnBackground" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/actions_button_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/player_two_counter_field">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reset_history_button"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"

                android:minWidth="128dip"
                android:text="@string/reset_history_label"
                app:cornerRadius="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@+id/play_history_button"
                app:layout_constraintTop_toBottomOf="@+id/play_history_button"
                app:layout_constraintVertical_bias="0.0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/inf_names_buttons"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:layout_marginTop="16dp"
                android:minWidth="128dip"
                android:text="@string/inf_names"
                app:cornerRadius="1dp"
                app:layout_constraintStart_toStartOf="@+id/play_history_button"
                app:layout_constraintTop_toBottomOf="@+id/play_history_button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/play_history_button"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:minWidth="272dp"

                android:text="@string/play_history_label"
                app:cornerRadius="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>




